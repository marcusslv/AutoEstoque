    "test:all": "pnpm exec vue-tsc --noEmit && pnpm test && pnpm test:e2e"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.468.0",
    "nuxt": "^4.0.0",
    "pinia": "^3.0.3",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9",
    "vue": "^3.5.35",
    "vue-tsc": "^3.1.4"
  },
  "packageManager": "pnpm@10.28.2"
